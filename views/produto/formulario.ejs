<div class="row">
        <div class="col-12">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="">
              <h1 class="fs-3 mb-1">Novo Produto</h1>
              <p class="mb-0">Gerencie seu estoque</p>
            </div>
            <div>
              <a href="/marcas/criar" class="btn btn-primary">Adicionar Marcas</a>
              <a href="/categorias/criar" class="btn btn-primary">Adicionar Categorias</a>

            </div>

          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="card">
            <div class="card-body p-4">
              <form action="<%= produto && produto.id_pro ? '/produtos/' + produto.id_pro + '/editar' : '/produtos/criar' %>" method="post">
                
                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="productName" class="form-label">Nome do Produto</label>
                    <input type="text" class="form-control" id="productName" name="nome_pro" value="<%= produto?.nome_pro || '' %>" placeholder="Digite o nome do produto" required>
                  </div>
                  <div class="col-md-6 mb-3">
                    <label for="productStatus" class="form-label">Status</label>
                    <select class="form-select" name="status_pro" required>
                      <option value="">Selecione</option>
                      <option value="Ativo" <%= produto?.status_pro === 'Ativo' ? 'selected' : '' %>>Ativo</option>
                      <option value="Inativo" <%= produto?.status_pro === 'Inativo' ? 'selected' : '' %>>Inativo</option>
                   </select>
                  </div>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="productPrice" class="form-label">Preço</label>
                    <input type="number" class="form-control" id="productPrice" name="preco_pro" value="<%= produto?.preco_pro || '' %>" placeholder="0.00" step="0.01" required>
                  </div>
                  <div class="col-md-6 mb-3">
                    <label for="productStock" class="form-label">Quantidade</label>
                    <input type="number" class="form-control" id="productStock" name="quantidade_pro" value="<%= produto?.quantidade_pro || '' %>" placeholder="0" required>
                  </div>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="productMarca" class="form-label">Marca</label>
                    <select class="form-select" name="marca_pro" required>
                      <option value="">Selecione</option>
                      <% marcas.forEach(marca => { %>
                          <option value="<%= marca.id_mar %>" <%= produto?.marca_pro == marca.id_mar ? 'selected' : '' %>>
                              <%= marca.nome_mar %>
                          </option>
                      <% }) %>
                   </select>
                  </div>
                  <div class="col-md-6 mb-3">
                    <label for="productCategoria" class="form-label">Categoria</label>
                    <select class="form-select" name="categoria_pro" required>
                      <option value="">Selecione</option>
                     <% categorias.forEach(categoria => { %>
                          <option value="<%= categoria.id_cat %>" <%= produto?.categoria_pro == categoria.id_cat ? 'selected' : '' %>>
                              <%= categoria.nome_cat %>
                          </option>
                      <% }) %>
                   </select>
                  </div>
                </div>
            
                <div class="mb-3">
                  <label for="productImage" class="form-label">Imagem do Produto</label>
                  <input type="file" class="form-control" id="productImage" accept="image/*" name="imagem_pro">
                </div>

                <div class="mb-3">
                  <label for="productDescription" class="form-label">Descrição</label>
                  <textarea class="form-control" id="productDescription" rows="4" name="descricao_pro" placeholder="Insira uma descrição para o produto"><%= produto?.descricao_pro || '' %></textarea>
                </div>

                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary">Adicionar Produto</button>
                  <button type="reset" class="btn btn-secondary">Limpar</button>
                </div>
            
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
</main>