<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="">
        <h1 class="fs-3 mb-1">Novo Cliente</h1>
        <p class="mb-0">Adicione um novo cliente</p>
    </div>
</div>
<div class="card">
    <div class="card-body p-4">
<form    action="/clientes/criar" method="POST">


    <div class="col-md-12 mb-3">
        <label for="cliente" class="form-label">Nome do cliente</label>
        <input type="text" class="form-control" id="productName" name="nome_cli" placeholder="Digite o nome da cliente" required>
    </div>


<div class="row">

    <div class="col-md-6 mb-3">
        <label for="telefone" class="form-label">Telefone</label>
        <input type="text" class="form-control" id="productName" name="telefone_cli" placeholder="Digite o nome da cliente" required>
    </div>

    <div class="col-md-6 mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="text" class="form-control" id="productName" name="email_cli" placeholder="Digite o nome da cliente" required>
    </div>
    
    <div class="col-md-6 mb-3">
        <label for="dataNascimento" class="form-label">Data de Nascimento</label>
        <input type="date" class="form-control" id="productName" name="data_nascimento_cli" placeholder="Digite o nome da cliente" required>
    </div>

    <div class="col-md-6 mb-3">
        <label for="Endereco" class="form-label">Endereço</label>

        <select class="form-select" name="endereco_cli" required>
            <option value="">Selecione</option>

            <% enderecos.forEach(endereco => { %>
                <option value="<%= endereco.id_end %>">
                    <%= endereco.rua_end %>, Nº <%= endereco.numero_end %>
                </option>
            <% }) %>

        </select>
    </div>


</div>


    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Adicionar cliente</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
    </div>

</form>
</div>
</div>
</div>
