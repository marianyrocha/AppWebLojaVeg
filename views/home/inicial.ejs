<div class="container-fluid">
      <div class="row ">
        <div class="col-12">
          <div class="mb-6">
            <h1 class="fs-3 mb-1">Dashboard</h1>
            <p>Principais informações do sistema…</p>
          </div>
          <div class="row">

        </div>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-lg-3 col-12">

          <div class="card p-4  bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2">

            <div class="d-flex gap-3 ">
              <div class="icon-shape icon-md bg-primary text-white rounded-2">
                <i class="ti ti-report-analytics fs-4"></i>
              </div>
              <div>
                <h2 class="mb-3 fs-6">Total de Fornecedores</h2>
                <h3 class="fw-bold mb-0"><%= totalFornecedores %></h3>
                <h2></h2>
                <p class="text-primary mb-0 small"></p>
              </div>
            </div>
          </div>


        </div>
        <div class="col-lg-3 col-12">

          <div class="card p-4  bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2">

            <div class="d-flex gap-3 ">
              <div class="icon-shape icon-md bg-success text-white rounded-2">
                <i class="ti ti-repeat fs-4"></i>
              </div>
              <div>
                <h2 class="mb-3 fs-6">Total de Clientes</h2>
                <h3 class="fw-bold mb-0"><%= totalClientes %></h3>
              </div>
            </div>
          </div>


        </div>
        <div class="col-lg-3 col-12">

          <div class="card p-4  bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2">

            <div class="d-flex gap-3 ">
              <div class="icon-shape icon-md bg-info text-white rounded-2">
                <i class="ti ti-currency-dollar fs-4"></i>
              </div>
              <div>
                <h2 class="mb-3 fs-6">Total de Pedidos</h2>
                <h3 class="fw-bold mb-0"><%= totalPedidos %></h3>
              </div>
            </div>
          </div>


        </div>
        <div class="col-lg-3 col-12">

          <div class="card p-4  bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-2">

            <div class="d-flex gap-3 ">
              <div class="icon-shape icon-md bg-warning text-white rounded-2">
                <i class="ti ti-notes fs-4"></i>
              </div>
              <div>
                <h2 class="mb-3 fs-6">Total de Produtos</h2>
                <h3 class="fw-bold mb-0"><%= totalProdutos %></h3>
              </div>
            </div>
          </div>
        </div>



        




      <div class="row g-3">

        <!-- CARD 1 — Top Selling Products -->
        <div class="col-lg-4">
          <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
              <h4 class="mb-0 h5">Últimos Pedidos</h4>
            </div>

            <ul class="list-group list-group-flush">
            <% ultimosPedidos.forEach(pedido => { %>
            <li class="list-group-item">
                <div class="d-flex justify-content-between">
                    <span>Pedido #<%= pedido.id_ped %></span>
                    <span class="badge bg-success">
                        R$ <%= pedido.valor_ped %>
                    </span>
                </div>
            </li>
            <% }) %>
             

            </ul>
          </div>
        </div>

        <!-- CARD 2 — Low Stock Products -->


        <div class="col-lg-4">
          <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
              <div class="d-flex align-items-center">

                <h4 class="mb-0 h5">Estoque Baixo</h4>
              </div>
              <a href="/produtos" class="small text-primary text-decoration-underline">Ver Todos</a>
            </div>

            <ul class="list-group list-group-flush">

 
            
                <% estoqueBaixo.forEach(produto => { %>
              <li class="list-group-item d-flex align-items-center gap-3">
                <img src="/public/images/<%= produto.imagem_pro %>" class="rounded" width="48">
                <div class="flex-grow-1">
                  <p class="mb-1"><%= produto.nome_pro %></p>
                  <small>ID: #<%= produto.id_pro %></small>
                </div>
                <div class="d-flex flex-column gap-0 align-items-center">
                  <span class="fw-semibold text-primary"><%= produto.quantidade_pro %></span>
                  <small class="text-muted">Em Estoque</small>
                </div>
              </li>
            <% }) %>
            </ul>
          </div>
        </div>

        <!-- CARD 3 — Recent Sales -->


        <div class="col-lg-4">
          <div class="card  h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
              <h4 class="mb-0 h5">Produtos Mais Caros</h4>
              <a href="/produtos" class="small text-primary text-decoration-underline">Ver Todos</a>
            </div>

            <ul class="list-group list-group-flush">
        <% produtosCaros.forEach(produto => { %>
              <li class="list-group-item d-flex align-items-center gap-3">
                <img src="/public/images/<%= produto.imagem_pro%>" class="rounded" width="48">
                <div class="flex-grow-1">
                  <p class="mb-1"><%= produto.nome_pro %></p>
                  <div class="d-flex align-items-center gap-2 text-muted">
                    <small class="fw-semibold"></small>
                    <small>•</small>
                    <small>R$ <%= produto.preco_pro %></small>
                  </div>

                </div>
                <span class="badge bg-success-subtle text-success"><%= produto.status_pro %></span>
              </li>
              <% }) %>


            </ul>
          </div>
        </div>

      </div>
      <div class="row">
        <div class="col-12">

        </div>

      </div>

    </div>