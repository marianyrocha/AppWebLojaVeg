<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="">
        <h1 class="fs-3 mb-1">Novo cargo</h1>
        <p class="mb-0">Adicione um novo cargo</p>
    </div>
</div>
<div class="card">
    <div class="card-body p-4">
<form    action="/cargos/criar" method="POST">

    <div class="row">

        <div class="col-md-6 mb-3">
            <label for="productName" class="form-label">Nome do cargo</label>
            <input type="text" class="form-control" id="productName" name="nome_car" placeholder="Digite o nome do cargo" required>
        </div>

        <div class="col-md-6 mb-3">
            <label for="productPrice" class="form-label">Salário</label>
            <input type="number" class="form-control" id="productPrice" name="salario_car" placeholder="0.00" step="0.01" required>
        </div>
        
    </div>

    <div class="mb-3">
        <label for="productDescription" class="form-label">Descrição</label>
        <textarea class="form-control" id="productDescription" rows="4" name="descricao_car"
        placeholder="Insira uma descrição para o cargo"></textarea>
    </div>


    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Adicionar cargo</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
    </div>

</form>
</div>
</div>
</div>
