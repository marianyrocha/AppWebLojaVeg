<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="fs-3 mb-1"><%= fornecedor && fornecedor.id_for ? 'Editar Fornecedor' : 'Novo Fornecedor' %></h1>
            <p class="mb-0"><%= fornecedor && fornecedor.id_for ? 'Edite os dados do fornecedor' : 'Adicione um novo fornecedor' %></p>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-4">

            <form action="<%= rotaAtual %>" method="POST">

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Nome do Fornecedor</label>
                        <input type="text" class="form-control" name="nome_for"
                            value="<%= fornecedor.nome_for || '' %>"
                            placeholder="Digite o nome do fornecedor" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input type="text" class="form-control" name="email_for"
                            value="<%= fornecedor.email_for || '' %>"
                            placeholder="Digite o email" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Telefone</label>
                        <input type="text" class="form-control" name="telefone_for"
                            value="<%= fornecedor.telefone_for || '' %>"
                            placeholder="Digite o telefone" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Razão Social</label>
                        <input type="text" class="form-control" name="razao_social_for"
                            value="<%= fornecedor.razao_social_for || '' %>"
                            placeholder="Digite a razão social" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">CNPJ</label>
                        <input type="text" class="form-control" name="cnpj_for"
                            value="<%= fornecedor.cnpj_for || '' %>"
                            placeholder="Digite o CNPJ" required>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <%= fornecedor && fornecedor.id_for ? 'Salvar Alterações' : 'Adicionar Fornecedor' %>
                    </button>

                    <a href="/fornecedor" class="btn btn-secondary">Cancelar</a>
                </div>

            </form>

        </div>
    </div>
</div>