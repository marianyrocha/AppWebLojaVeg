<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="">
        <h1 class="fs-3 mb-1">Novo Fornecedor</h1>
        <p class="mb-0">Adicione um novo fornecedor</p>
    </div>
</div>
<div class="card">
    <div class="card-body p-4">
<form    action="/fornecedor/criar" method="POST">

    <div class="row">
        <div class="col-md-14 mb-3">
        <label for="productName" class="form-label">Nome do Fornecedor</label>
        <input type="text" class="form-control" id="productName" name="nome_for" placeholder="Digite o nome do fornecedor" required>
        </div>
    </div>
   
    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="productName" class="form-label">Email</label>
            <input type="text" class="form-control" id="productName" name="email_for" placeholder="Digite o email" required>
        </div>

        <div class="col-md-6 mb-3">
            <label for="productName" class="form-label">Telefone</label>
            <input type="text" class="form-control" id="productName" name="telefone_for" placeholder="Digite o telefone" required>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="productName" class="form-label">Razão Social</label>
            <input type="text" class="form-control" id="productName" name="razao_social_for" placeholder="Digite a razão social" required>
        </div>

        <div class="col-md-6 mb-3">
            <label for="productName" class="form-label">CNPJ</label>
            <input type="text" class="form-control" id="productName" name="cnpj_for" placeholder="Digite o CNPJ" required>
        </div>
    </div>


    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Adicionar Fornecedor</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
    </div>

</form>
</div>
</div>
</div>
