<% fornecedor = locals.fornecedor || {} %>

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= locals.titulo %></h4>
            <p class="mb-0">&raquo; Gerenciamento de Fornecedores</p>
        </div>
    </div>

    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/fornecedor">Consulta de Fornecedores</a></li>
            <li class="breadcrumb-item active">
                <a href="javascript:void(0)">Excluir Fornecedor</a>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="card border-danger">

            <div class="card-header bg-danger p-3">
                <h4 class="card-title text-white mb-0">
                    Exclusão de fornecedor
                </h4>
            </div>

            <div class="card-body">

                <div class="alert alert-warning">
                    <b>Esta ação excluirá o registro de forma permanente.</b>
                </div>

                <p class="mb-4">
                    Tem certeza que deseja excluir o fornecedor abaixo?
                </p>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th>ID</th>
                                <td>#<%= fornecedor.id_for %></td>
                            </tr>

                            <tr>
                                <th>Nome</th>
                                <td><%= fornecedor.nome_for %></td>
                            </tr>

                            <tr>
                                <th>Email</th>
                                <td><%= fornecedor.email_for %></td>
                            </tr>

                            <tr>
                                <th>Telefone</th>
                                <td><%= fornecedor.telefone_for %></td>
                            </tr>

                            <tr>
                                <th>Razão Social</th>
                                <td><%= fornecedor.razao_social_for %></td>
                            </tr>

                            <tr>
                                <th>CNPJ</th>
                                <td><%= fornecedor.cnpj_for %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <form action="/fornecedor/<%= fornecedor.id_for %>/excluir" method="post">
                    <button type="submit" class="btn btn-danger mr-2">
                        Confirmar Exclusão
                    </button>

                    <a href="/fornecedor" class="btn btn-secondary">
                        Cancelar
                    </a>
                </form>

            </div>
        </div>
    </div>
</div>