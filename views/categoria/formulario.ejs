<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="">
        <h1 class="fs-3 mb-1">Nova Categoria</h1>
        <p class="mb-0">Adicione uma nova categoria</p>
    </div>
</div>
<div class="card">
    <div class="card-body p-4">
<form    action="/categorias/criar" method="POST">

<div class="row">
    <div class="col-md-6 mb-3">
        <label for="productName" class="form-label">Nome da Categoria</label>
        <input type="text" class="form-control" id="productName" name="nome_cat" placeholder="Digite o nome da categoria" required>
    </div>

    <div class="col-md-6 mb-3">
         <label for="productStock" class="form-label">Status</label>
            <select class="form-select" name="status_cat" required>
              <option value="">Selecione</option>
              <option value="Ativa">Ativa</option>
              <option value="Inativa">Inativa</option>
            </select>
    </div>
</div>

    <div class="mb-3">
        <label for="productDescription" class="form-label">Descrição</label>
        <textarea class="form-control" id="productDescription" rows="4" name="descricao_cat"
        placeholder="Insira uma descrição para a categoria"></textarea>
    </div>


    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Adicionar Categoria</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
    </div>

</form>
</div>
</div>
</div>
