
      <div class="row">
        <div class="col-12">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="">
              <h1 class="fs-3 mb-1">Pedidos</h1>
              <p class="mb-0">Gerencie seus pedidos</p>
            </div>
            <div>
              <a href="create-product.html" class="btn btn-primary">Adicionar Pedido</a>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div>
            <div class="d-flex gap-2 mb-3 flex-wrap justify-content-between">
              <input type="text" class="form-control" placeholder="Search products..." style="max-width: 250px;">
              <div class="d-flex gap-2">

                <button class="btn btn-outline-secondary">
                  <i class="ti ti-filter"></i> Filter
                </button>
                <button class="btn btn-outline-secondary">
                  <i class="ti ti-file-excel"></i> Excel
                </button>
                <button class="btn btn-outline-secondary">
                  <i class="ti ti-file-pdf"></i> PDF
                </button>
              </div>
            </div>
          </div>
          <div class="card table-responsive ">
            <table class="table mb-0 text-nowrap table-hover">
              <thead class="table-light border-light">
                <tr>
                  <th>Data</th>

                  <th>Valor</th>
                  <th>Pagamento</th>
                  <th>Funcionario</th>
                  <th>Cliente</th>
                  <th>Status</th>
                </tr>
              </thead>

                <tbody>
                  <% pedidos.forEach(pedido => { %>
                    <tr class="align-middle">
                      
                    <td>
                        <%= pedido.data_ped %>
                    </td>    


 
                    
                      <td>
                        R$ <%= pedido.valor_ped %>
                      </td>




                      <td>
                        <%= pedido.forma_pagamento_ped %>
                      </td>

                      <td>
                        <%= pedido.funcionario?.nome_fun %>
                      </td>

                      <td>
                        <%= pedido.cliente?.nome_cli %>
                      </td>

                    <td>
                        <span class="ms-3">
                            <%= pedido.status_ped %>
                        </span>
                    </td>

                      <td>
                        <a href="/pedidos/<%= pedido.id_ped %>/editar">
                          <i class="ti ti-edit"></i>
                        </a>

                        <a href="/pedidos/<%= pedido.id_ped %>/excluir"
                          class="link-danger">
                          <i class="ti ti-trash ms-2"></i>
                        </a>
                      </td>

                    </tr>
                  <% }) %>
                </tbody>

                <tr>
                  <td class="border-bottom-0">Mostrando pedidos por página</td>
                  <td colspan="9" class="border-bottom-0">
                    <nav aria-label="Page navigation" class="d-flex justify-content-end">
                      <ul class="pagination mb-0">
                        <li class="page-item disabled">
                          <a class="page-link" href="#" tabindex="-1">Prévia</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                          <a class="page-link" href="#">Próxima</a>
                        </li>
                      </ul>
                    </nav>
                  </td>
                </tr>

              </tfoot>
            </table>
          </div>
        </div>

      </div>

