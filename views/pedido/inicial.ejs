
      <div class="row">
        <div class="col-12">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="">
              <h1 class="fs-3 mb-1">Pedidos</h1>
              <p class="mb-0">Gerencie seus pedidos</p>
            </div>
            <div>
              <a href="create-product.html" class="btn btn-primary">Adicionar Pedido</a>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div>
            <div class="d-flex gap-2 mb-3 flex-wrap justify-content-between">
              <input type="text" class="form-control" placeholder="Search products..." style="max-width: 250px;">
              <div class="d-flex gap-2">

                <button class="btn btn-outline-secondary">
                  <i class="ti ti-filter"></i> Filter
                </button>
                <button class="btn btn-outline-secondary">
                  <i class="ti ti-file-excel"></i> Excel
                </button>
                <button class="btn btn-outline-secondary">
                  <i class="ti ti-file-pdf"></i> PDF
                </button>
              </div>
            </div>
          </div>
          <div class="card table-responsive ">
            <table class="table mb-0 text-nowrap table-hover">
              <thead class="table-light border-light">
                <tr>
                  <th>Data</th>

                  <th>Valor</th>
                  <th>Pagamento</th>
                  <th>Funcionario</th>
                  <th>Cliente</th>
                  <th>Status</th>
                  <th>Ações</th>
                </tr>
              </thead>

<tbody>
  <% pedidos.forEach(pedido => { %>
    <tr class="align-middle">
      <td>
        <%= new Date(pedido.data_ped).toLocaleDateString('pt-BR') %>
      </td>    

      <td>
        R$ <%= Number(pedido.valor_ped).toFixed(2).replace('.', ',') %>
      </td>

      <td>
        <%= pedido.forma_pagamento_ped %>
      </td>

      <td>
        <%= pedido.funcionario?.nome_fun || 'Não atribuído' %>
      </td>

      <td>
        <%= pedido.cliente?.nome_cli || 'Cliente não informado' %>
      </td>

      <td>
        <span class="badge bg-primary">
            <%= pedido.status_ped %>
        </span>
      </td>

      <td>
        <button class="btn btn-sm btn-outline-info me-2" 
                type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#collapse-pedido-<%= pedido.id_ped %>" 
                aria-expanded="false" 
                title="Ver Produtos">
            <i class="bi bi-eye-fill"></i>
        </button>
 <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">


        <a href="/produto-pedido/criar?pedidoId=<%= pedido.id_ped %>" class="text-success me-2" title="Adicionar Produtos">
            <i class="bi bi-bag-plus-fill fs-5"></i>
        </a>

        <a href="/pedidos/<%= pedido.id_ped %>/editar" class="text-secondary me-2" title="Editar Pedido">
            <i class="bi bi-pencil-square fs-5"></i>
        </a>

        <a href="/pedidos/<%= pedido.id_ped %>/excluir" class="text-danger" title="Excluir Pedido">
            <i class="bi bi-trash fs-5"></i>
        </a>
      </td>
    </tr>

<tr>
  <td colspan="7" class="p-0 border-0">
    <div class="collapse" id="collapse-pedido-<%= pedido.id_ped %>">
      
      <div class="card shadow-none border mb-0 bg-light">
        <div class="card-header bg-white py-2">
          <h6 class="mb-0 text-muted fs-7 fw-bold">Produtos deste Pedido (#<%= pedido.id_ped %>)</h6>
        </div>
        <div class="card-body p-3">
          <table class="table table-sm table-bordered mb-0 bg-white">
            <thead class="table-light text-uppercase" style="font-size: 0.85rem;">
              <tr>
                <th>Produto</th>
                <th class="text-center">Qtd</th>
                <th class="text-end">Preço Unit.</th>
                <th class="text-end">Subtotal</th>
              </tr>
            </thead>
            <tbody style="font-size: 0.85rem;">
              <% if (pedido.produtoPedidos && pedido.produtoPedidos.length > 0) { %>
                <% pedido.produtoPedidos.forEach(item => { %>
                  <tr>
                    <td class="fw-bold text-secondary"><%= item.produto?.nome_pro || 'Produto excluído' %></td>
                    <td class="text-center"><%= item.quantidade_pro_ped %></td>
                    <td class="text-end">R$ <%= Number(item.preco_unitario_pro_ped).toFixed(2).replace('.', ',') %></td>
                    <td class="text-end fw-bold text-dark">
                      R$ <%= (Number(item.quantidade_pro_ped) * Number(item.preco_unitario_pro_ped)).toFixed(2).replace('.', ',') %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-3">
                    Nenhum produto adicionado a este pedido.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      
    </div> </td>
</tr>
<% }) %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</tbody>
<tfoot>
                <tr>
                  <td class="border-bottom-0">Mostrando pedidos por página</td>
                  <td colspan="6" class="border-bottom-0">
                    <nav aria-label="Page navigation" class="d-flex justify-content-end">
                      <ul class="pagination mb-0">
                        <li class="page-item disabled">
                          <a class="page-link" href="#" tabindex="-1">Prévia</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                          <a class="page-link" href="#">Próxima</a>
                        </li>
                      </ul>
                    </nav>
                  </td>
                </tr>

              </tfoot>
            </table>
          </div>
        </div>
      </div>

