<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="fs-3 mb-1">Pedidos</h1>
        <p class="mb-0">Gerencie seus pedidos</p>
      </div>

      <div>
        <a href="/pedidos/criar" class="btn btn-primary">Adicionar Pedido</a>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">

    <form action="/pedidos" method="GET" class="d-flex gap-2 mb-3 flex-wrap justify-content-between">

      <input type="text" name="termo" class="form-control"
        placeholder="Buscar pedidos..."
        style="max-width: 970px;"
        value="<%= typeof termo !== 'undefined' ? termo : '' %>">

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a href="/pedidos" class="btn btn-outline-secondary">Limpar</a>
      </div>

    </form>

    <div class="card table-responsive">

      <table class="table mb-0 text-nowrap table-hover">

        <thead class="table-light border-light">
          <tr>
            <th>Data</th>
            <th>Valor</th>
            <th>Pagamento</th>
            <th>Funcionario</th>
            <th>Cliente</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>

        <tbody>

          <% pedidos.forEach(pedido => { %>

          <tr class="align-middle">
            <td><%= new Date(pedido.data_ped).toLocaleDateString('pt-BR') %></td>

            <td>R$ <%= Number(pedido.valor_ped).toFixed(2).replace('.', ',') %></td>

            <td><%= pedido.forma_pagamento_ped %></td>

            <td><%= pedido.funcionario?.nome_fun || 'Não atribuído' %></td>

            <td><%= pedido.cliente?.nome_cli || 'Cliente não informado' %></td>

            <td><span class="badge bg-primary"><%= pedido.status_ped %></span></td>

            <td>
              <button class="btn btn-sm btn-outline-info me-2"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapse-pedido-<%= pedido.id_ped %>">
                <i class="bi bi-eye-fill"></i>
              </button>

              <a href="/produto-pedido/criar?pedidoId=<%= pedido.id_ped %>"
                class="text-success me-2">
                <i class="bi bi-bag-plus-fill fs-5"></i>
              </a>

              <a href="/pedidos/<%= pedido.id_ped %>/editar"
                class="text-secondary me-2">
                <i class="bi bi-pencil-square fs-5"></i>
              </a>

              <a href="/pedidos/<%= pedido.id_ped %>/excluir"
                class="text-danger">
                <i class="bi bi-trash fs-5"></i>
              </a>
            </td>
          </tr>

          <tr>
            <td colspan="7" class="p-0 border-0">
              <div class="collapse" id="collapse-pedido-<%= pedido.id_ped %>">

                <div class="card shadow-none border mb-0 bg-light">

                  <div class="card-header bg-white py-2">
                    <h6 class="mb-0 text-muted">
                      Produtos do Pedido (#<%= pedido.id_ped %>)
                    </h6>
                  </div>

                  <div class="card-body p-3">

                    <table class="table table-sm table-bordered mb-0 bg-white">

                      <thead class="table-light">
                        <tr>
                          <th>Produto</th>
                          <th class="text-center">Qtd</th>
                          <th class="text-end">Preço</th>
                          <th class="text-end">Subtotal</th>
                        </tr>
                      </thead>
                      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

                      <tbody>

                        <% if (pedido.produtoPedidos?.length) { %>

                          <% pedido.produtoPedidos.forEach(item => { %>
                            <tr>
                              <td><%= item.produto?.nome_pro %></td>
                              <td class="text-center"><%= item.quantidade_pro_ped %></td>
                              <td class="text-end">R$ <%= Number(item.preco_unitario_pro_ped).toFixed(2) %></td>
                              <td class="text-end">
                                R$ <%= (item.quantidade_pro_ped * item.preco_unitario_pro_ped).toFixed(2) %>
                              </td>
                            </tr>
                          <% }) %>

                        <% } else { %>
                          <tr>
                            <td colspan="4" class="text-center text-muted">
                              Nenhum produto
                            </td>
                          </tr>
                        <% } %>

                      </tbody>

                    </table>

                  </div>

                </div>

              </div>
            </td>
          </tr>

          <% }) %>

        </tbody>

      </table>

    </div>
  </div>
</div>