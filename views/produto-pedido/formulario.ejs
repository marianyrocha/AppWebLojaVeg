<form action="<%= item?.id_ped_pro ? '/produto-pedido/' + item.id_ped_pro + '/editar' : '/produto-pedido/criar' %>" method="POST">

<div class="row">

  <div class="col-md-6 mb-3">
    <label class="form-label">Produto</label>
    <select class="form-select" name="produto_id" required>
      <option value="">Selecione</option>

      <% (produtos || []).forEach(produto => { %>
        <option value="<%= produto.id_pro %>"
          <%= item?.produto?.id_pro === produto.id_pro ? 'selected' : '' %>>
          <%= produto.nome_pro %>
        </option>
      <% }) %>

    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Pedido</label>
    <select class="form-select" name="pedido_id" required>
      <option value="">Selecione</option>

      <% (pedidos || []).forEach(pedido => { %>
        <option value="<%= pedido.id_ped %>"
          <%= item?.pedido?.id_ped === pedido.id_ped ? 'selected' : '' %>>
          Pedido #<%= pedido.id_ped %>
        </option>
      <% }) %>

    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Quantidade</label>
    <input type="number" class="form-control" name="quantidade_pro_ped"
      value="<%= item?.quantidade_pro_ped || '' %>" required>
  </div>

  <div class="col-md-6 mb-3">
    <label class="form-label">Preço Unitário</label>
    <input type="number" step="0.01" class="form-control" name="preco_unitario_pro_ped"
      value="<%= item?.preco_unitario_pro_ped || '' %>" required>
  </div>

</div>

<div class="d-flex gap-2">
  <button type="submit" class="btn btn-primary">Salvar</button>
  <button type="reset" class="btn btn-secondary">Limpar</button>
</div>

</form>