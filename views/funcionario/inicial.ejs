<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fs-3 mb-1">Funcionários</h1>
                <p class="mb-0">Gerencie seus funcionários</p>
            </div>
            <div>
                <a href="/funcionarios/criar" class="btn btn-primary">
                    Adicionar Funcionário
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">

        <form action="/funcionarios" method="GET"
            class="d-flex gap-2 mb-3 flex-wrap justify-content-between">

            <input
                type="text"
                name="termo"
                class="form-control"
                placeholder="Buscar funcionário..."
                style="max-width: 970px;"
                value="<%= typeof termo !== 'undefined' ? termo : '' %>">

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Buscar
                </button>

                <a href="/funcionarios" class="btn btn-outline-secondary">
                    Limpar
                </a>
            </div>

        </form>

        <div class="card table-responsive">

            <table class="table mb-0 text-nowrap table-hover">

                <thead class="table-light border-light">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Telefone</th>
                        <th>CPF</th>
                        <th>Cargo</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>

                <tbody>

                    <% funcionarios.forEach(funcionario => { %>

                        <tr class="align-middle">

                            <td><%= funcionario.nome_fun %></td>

                            <td><%= funcionario.email_fun %></td>

                            <td><%= funcionario.telefone_fun %></td>

                            <td><%= funcionario.cpf_fun %></td>

                            <td><%= funcionario.cargo_fun?.nome_car || '-' %></td>

                            <td>
                                <% if (funcionario.status_fun === 'Ativo') { %>
                                    <span class="badge bg-success">Ativo</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Inativo</span>
                                <% } %>
                            </td>

                            <td>

                                <a href="/funcionarios/<%= funcionario.id_fun %>/editar"
                                    class="text-secondary me-2"
                                    title="Editar Funcionário">

                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>

                                <a href="/funcionarios/<%= funcionario.id_fun %>/excluir"
                                    class="text-danger"
                                    title="Excluir Funcionário">

                                    <i class="bi bi-trash fs-5"></i>
                                </a>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>
</div>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">