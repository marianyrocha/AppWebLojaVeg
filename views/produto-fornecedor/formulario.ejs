<div class="row">
  <div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
      <div>
        <h1 class="fs-3 mb-1">Novo Item</h1>
        <p class="mb-0">Gerencie os itens do catálogo</p>
      </div>
      <div>
        <a href="/fornecedor/criar" class="btn btn-primary">Adicionar Fornecedor</a>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body p-4">
        <form action="<%= item?.id_pro_for ? '/produto-fornecedor/' + item.id_pro_for + '/editar' : '/produto-fornecedor/criar' %>" method="POST">

          <div class="mb-3">
            <label class="form-label">Produto</label>
            <select class="form-select" name="produto_id" required>
              <option value="">Selecione um produto</option>
              <% produtos.forEach(produto => { %>
                <option value="<%= produto.id_pro %>" <%= item?.produto?.id_pro == produto.id_pro ? 'selected' : '' %>>
                  <%= produto.nome_pro %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Fornecedor</label>
            <select class="form-select" name="fornecedor_id" required>
              <option value="">Selecione um fornecedor</option>
              <% fornecedores.forEach(fornecedor => { %>
                <option value="<%= fornecedor.id_for %>" <%= item?.fornecedor?.id_for == fornecedor.id_for ? 'selected' : '' %>>
                  <%= fornecedor.nome_for %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Quantidade</label>
            <input type="number" class="form-control" name="quantidade_pro_for" value="<%= item?.quantidade_pro_for || '' %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Preço Unitário</label>
            <input type="number" step="0.01" class="form-control" name="preco_unitario_pro_for" value="<%= item?.preco_unitario_pro_for || '' %>" required>
          </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <button type="reset" class="btn btn-secondary">Limpar</button>
        </div>
        </form>
      </div>
    </div>
  </div>
</div>