<div class="col-12">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="">
        <h1 class="fs-3 mb-1">Nova Marca</h1>
        <p class="mb-0">Adicione uma nova marca</p>
    </div>
</div>
<div class="card">
    <div class="card-body p-4">
 <form action="/marcas/criar" method="POST">


    <div class="col-md-14 mb-3">
        <label for="productName" class="form-label">Nome da Marca</label>
        <input type="text" class="form-control" id="productName" name="nome_mar" placeholder="Digite o nome da marca" required>
    </div>

    <div class="col-md-14 mb-3">
        <label for="productName" class="form-label">Contato</label>
        <input type="text" class="form-control" id="productName" name="contato_mar" placeholder="Digite o contato" required>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Adicionar Marca</button>
        <button type="reset" class="btn btn-secondary">Limpar</button>
    </div>

</form>
</div>
</div>
</div>
